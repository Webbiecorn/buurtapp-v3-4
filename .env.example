# =====================================================
# Buurtconciërge App — Environment Variables Template
# Kopieer dit naar .env.local en vul echte waarden in.
# NOOIT committen! .env.local staat al in .gitignore.
# =====================================================

VITE_API_URL="https://us-central1-buurtapp-v3-4.cloudfunctions.net/api"
VITE_USE_EMULATORS=false

# ── Firebase ──────────────────────────────────────────
# Haal alle waarden op van Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
# De volgende zijn ook beschikbaar in src/firebase.ts (hardcoded):
# VITE_FIREBASE_AUTH_DOMAIN=buurtapp-v3-4.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=buurtapp-v3-4
# VITE_FIREBASE_STORAGE_BUCKET=buurtapp-v3-4.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=740445217879
# VITE_FIREBASE_APP_ID=1:740445217879:web:afa1154ca0c5894a29af12

# ── Google Maps ───────────────────────────────────────
# BELANGRIJK: Genereer NIEUWE keys op https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=YOUR_NEW_GOOGLE_MAPS_API_KEY_HERE
VITE_GOOGLE_MAP_LIGHT_ID=a685a3b57e7894f1a94dffc2
VITE_GOOGLE_MAP_DARK_ID=a685a3b57e7894f1a94dffc2

# ── Google Gemini AI ──────────────────────────────────
# Haal je NIEUWE API key op van: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=YOUR_NEW_GEMINI_API_KEY_HERE
